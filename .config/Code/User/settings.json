{
  "workbench.iconTheme": "material-icon-theme",
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook"
  },
  "explorer.confirmDragAndDrop": false,
  "security.workspace.trust.untrustedFiles": "open",
  "explorer.confirmDelete": false,
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "workbench.startupEditor": "none",
  "json.maxItemsComputed": 15000,
  "editor.fontFamily": "'Mononoki Nerd Font Mono', 'CaskaydiaCove Nerd Font'",
  "editor.fontSize": 16,
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.rulers": [80],
    "editor.selectionHighlight": false,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": false
  },
  "editor.renderWhitespace": "none",
  "editor.minimap.enabled": false,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "C_Cpp.clang_format_fallbackStyle": "{ BasedOnStyle: Chromium, UseTab: Never, IndentWidth: 2, TabWidth: 4, ColumnLimit: 100}",
  "editor.formatOnSave": true,
  "C_Cpp.codeAnalysis.updateDelay": 500,
  "eslint.format.enable": true,
  "[python]": {
    "editor.defaultFormatter": "ms-python.python"
  },
  "redhat.telemetry.enabled": false,
  "editor.tabSize": 2,
  "editor.detectIndentation": false,
  "python.formatting.autopep8Args": ["\"--max-line-length=80\""],
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.inlineSuggest.enabled": true,
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "window.zoomLevel": 2,
  "glassit-linux.opacity": 50,
  "workbench.colorTheme": "GitHub Dark",
  "editor.cursorBlinking": "expand",
  "workbench.activityBar.visible": false
}
